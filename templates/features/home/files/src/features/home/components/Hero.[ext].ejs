<% if (ui === 'shadcn') { %>
<% if (router === 'react-router') { %>
import { Link } from 'react-router';
<% } else { %>
import { Link } from '@tanstack/react-router';
<% } %>
import { Button } from '@/components/ui/button';
<% } else { %>
<% if (router === 'react-router') { %>
import { useNavigate } from 'react-router';
<% } else { %>
import { useNavigate } from '@tanstack/react-router';
<% } %>
import { Button } from '@heroui/react';
<% } %>

export default function Hero() {
<% if (ui === 'heroui') { %>
  const navigate = useNavigate();
<% } %>
  return (
    <section className="flex flex-1 flex-col items-center justify-center gap-6 px-4 py-24 text-center">
      <h1 className="text-4xl font-bold tracking-tight sm:text-6xl">
        Welcome to <span className="text-primary"><%= name %></span>
      </h1>
      <p className="max-w-xl text-lg text-muted-foreground">
        A modern React starter with authentication, dashboards, and everything you need to ship fast.
      </p>
      <div className="flex flex-wrap items-center justify-center gap-3">
<% if (ui === 'shadcn') { %>
        <Button asChild size="lg">
          <Link to="/signup">Get started</Link>
        </Button>
        <Button asChild variant="outline" size="lg">
          <Link to="/login">Sign in</Link>
        </Button>
<% } else { %>
        <Button variant="primary" size="lg" onPress={() => {
<% if (router === 'react-router') { %>
          navigate('/signup');
<% } else { %>
          void navigate({ to: '/signup' });
<% } %>
        }}>Get started</Button>
        <Button variant="outline" size="lg" onPress={() => {
<% if (router === 'react-router') { %>
          navigate('/login');
<% } else { %>
          void navigate({ to: '/login' });
<% } %>
        }}>Sign in</Button>
<% } %>
      </div>
    </section>
  );
}
