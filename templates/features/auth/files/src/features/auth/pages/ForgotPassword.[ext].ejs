import { useState } from 'react';
<% if (router === 'react-router') { %>
import { Link } from 'react-router';
<% } else { %>
import { Link } from '@tanstack/react-router';
<% } %>
<% if (ui === 'shadcn') { %>
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from '@/components/ui/card';
<% } else { %>
import { Button, Input, Card, CardHeader, CardBody, CardFooter } from '@heroui/react';
<% } %>

export default function ForgotPassword() {
  const [email, setEmail] = useState('');
  const [sent, setSent] = useState(false);
  const [isPending, setIsPending] = useState(false);

  const handleSubmit = async (e<% if (isTS) { %>: React.FormEvent<% } %>) => {
    e.preventDefault();
    setIsPending(true);
    await new Promise(r => setTimeout(r, 600)); // mock delay
    setSent(true);
    setIsPending(false);
  };

  return (
    <div className="flex min-h-screen items-center justify-center bg-background p-4">
<% if (ui === 'shadcn') { %>
      <Card className="w-full max-w-md">
        <CardHeader>
          <CardTitle className="text-2xl">Reset password</CardTitle>
          <CardDescription>
            {sent ? 'Check your inbox for a reset link.' : "Enter your email and we'll send a reset link."}
          </CardDescription>
        </CardHeader>
        {!sent && (
          <form onSubmit={handleSubmit}>
            <CardContent className="space-y-4">
              <div className="space-y-2">
                <Label htmlFor="email">Email</Label>
                <Input id="email" type="email" placeholder="you@example.com" value={email} onChange={e => setEmail(e.target.value)} required />
              </div>
            </CardContent>
            <CardFooter className="flex flex-col gap-3">
              <Button type="submit" className="w-full" disabled={isPending}>
                {isPending ? 'Sending…' : 'Send reset link'}
              </Button>
            </CardFooter>
          </form>
        )}
        <CardFooter>
          <Link to="/login" className="text-sm text-muted-foreground underline underline-offset-4 hover:text-primary">
            Back to sign in
          </Link>
        </CardFooter>
      </Card>
<% } else { %>
      <Card className="w-full max-w-md p-2">
        <CardHeader className="flex flex-col gap-1 pb-0">
          <h1 className="text-2xl font-bold">Reset password</h1>
          <p className="text-small text-default-500">
            {sent ? 'Check your inbox for a reset link.' : "Enter your email and we'll send a reset link."}
          </p>
        </CardHeader>
        {!sent && (
          <form onSubmit={handleSubmit}>
            <CardBody>
              <Input label="Email" type="email" placeholder="you@example.com" value={email} onValueChange={setEmail} isRequired />
            </CardBody>
            <CardFooter className="flex flex-col gap-3">
              <Button type="submit" color="primary" className="w-full" isLoading={isPending}>
                Send reset link
              </Button>
            </CardFooter>
          </form>
        )}
        <CardFooter>
          <Link to="/login" className="text-small text-default-500 underline">Back to sign in</Link>
        </CardFooter>
      </Card>
<% } %>
    </div>
  );
}
