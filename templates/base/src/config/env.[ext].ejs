<% if (isTS) { %>
interface AppEnv {
  apiUrl: string;
  appName: string;
}

export const env: AppEnv = {
  apiUrl: import.meta.env.VITE_API_URL ?? '/api',
  appName: import.meta.env.VITE_APP_NAME ?? '<%= name %>',
};
<% } else { %>
export const env = {
  apiUrl: import.meta.env.VITE_API_URL ?? '/api',
  appName: import.meta.env.VITE_APP_NAME ?? '<%= name %>',
};
<% } %>
