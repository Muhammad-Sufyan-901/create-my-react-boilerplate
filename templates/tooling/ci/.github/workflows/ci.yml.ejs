name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  ci:
    name: Lint · Type-check · Test · Build
    runs-on: ubuntu-latest
    strategy:
      matrix:
        node-version: [20, 22]

    steps:
      - uses: actions/checkout@v4

      - name: Set up Node ${{ matrix.node-version }}
        uses: actions/setup-node@v4
        with:
          node-version: ${{ matrix.node-version }}
<% if (pm === 'pnpm') { %>
      - name: Set up pnpm
        uses: pnpm/action-setup@v4
        with:
          version: latest

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Lint
        run: pnpm lint

<% if (isTS) { %>      - name: Type-check
        run: pnpm tsc -b --noEmit
<% } %>
      - name: Test
        run: pnpm test

      - name: Build
        run: pnpm build
<% } else if (pm === 'bun') { %>
      - name: Set up Bun
        uses: oven-sh/setup-bun@v2

      - name: Install dependencies
        run: bun install --frozen-lockfile

      - name: Lint
        run: bun run lint

<% if (isTS) { %>      - name: Type-check
        run: bun run tsc -b --noEmit
<% } %>
      - name: Test
        run: bun run test

      - name: Build
        run: bun run build
<% } else if (pm === 'yarn') { %>
      - name: Install dependencies
        run: yarn install --frozen-lockfile

      - name: Lint
        run: yarn lint

<% if (isTS) { %>      - name: Type-check
        run: yarn tsc -b --noEmit
<% } %>
      - name: Test
        run: yarn test

      - name: Build
        run: yarn build
<% } else { %>
      - name: Install dependencies
        run: npm ci

      - name: Lint
        run: npm run lint

<% if (isTS) { %>      - name: Type-check
        run: npm run tsc -- -b --noEmit
<% } %>
      - name: Test
        run: npm test

      - name: Build
        run: npm run build
<% } %>
