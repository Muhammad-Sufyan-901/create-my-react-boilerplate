{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true
  },
  "include": ["src", "vite.config.js"]
}
