{
  "name": "create-my-react-boilerplate",
  "version": "0.1.0",
  "description": "Scaffold a modern React app with Landing, Auth, User Dashboard, and Admin Dashboard — choose your language, router, and UI library.",
  "type": "module",
  "main": "dist/index.mjs",
  "bin": {
    "create-my-react-boilerplate": "dist/index.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/index.mjs",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "boilerplate",
    "cli",
    "vite",
    "typescript",
    "tailwind",
    "shadcn",
    "heroui",
    "react-router",
    "tanstack-router",
    "scaffold"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "ejs": "^5.0.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "pacote": "^21.5.0",
    "picocolors": "^1.1.1",
    "validate-npm-package-name": "^7.0.2"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@types/pacote": "^11.1.8",
    "@types/validate-npm-package-name": "^4.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
